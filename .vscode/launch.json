{
    // После запуска приложения доступны:
    //   Просмотр техпроцессов: http://localhost:5000
    //   Entity Viewer:         http://localhost:5000/entity-viewer
    //   API документация:      http://localhost:5000/api/docs
    //   ILS Report Agent:      http://localhost:5001
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Flask App (Debug)",
            "type": "debugpy",
            "request": "launch",
            "module": "flask",
            "args": [
                "--app", "app:app",
                "run",
                "--debug",
                "--port", "5000"
            ],
            "env": {
                "FLASK_ENV": "development"
            },
            "python": "${workspaceFolder}/.venv/Scripts/python.exe",
            "jinja": true,
            "autoStartBrowser": false,
            "console": "integratedTerminal"
        },
        {
            "name": "Python: app.py",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/app.py",
            "env": {
                "FLASK_ENV": "development"
            },
            "python": "${workspaceFolder}/.venv/Scripts/python.exe",
            "jinja": true,
            "console": "integratedTerminal"
        },
        {
            "name": "ILS Report Agent",
            "type": "debugpy",
            "request": "launch",
            "module": "ILS.app",
            "envFile": "${workspaceFolder}/ILS/.env",
            "jinja": true,
            "console": "integratedTerminal",
            "serverReadyAction": {
                "pattern": "ILS Report Agent: (https?://[a-zA-Z0-9.:/_-]+)",
                "uriFormat": "%s",
                "action": "openExternally"
            }
        }
    ]
}
